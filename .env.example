# Spring Boot 配置 (使用标准属性格式)
spring.application.name=knowledge
spring.servlet.multipart.max-file-size=50MB
spring.servlet.multipart.max-request-size=50MB

# Ollama 配置
ollama.base-url=http://localhost:11434
ollama.chat-model=qwen3.5:2b
ollama.embedding-model=qwen3-embedding:0.6b
ollama.timeout=120s
ollama.think=false

# Qdrant 配置
qdrant.host=localhost
qdrant.port=6334
qdrant.http-port=6333
qdrant.collection-name=knowledge
qdrant.vector-size=1024
qdrant.create-collection-if-not-exists=true

# RAG 配置
rag.chunk-size=500
rag.chunk-overlap=50
rag.max-results=5
rag.min-score=0.5
rag.memory-window=6
rag.session-ttl-seconds=1800
rag.memory-cleanup-interval-ms=300000

# 日志配置
logging.level.root=INFO
logging.level.com.mark.knowledge=DEBUG
logging.level.dev.langchain4j=DEBUG
